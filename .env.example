# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (PostgreSQL)
# For local development:
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/laxodds

# For production (e.g., Railway, Render, Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration
JWT_EXPIRES_IN=7d

# Scraping Schedule (cron format: minute hour day month weekday)
# Default: Every 6 hours
SCRAPE_CRON=0 */6 * * *

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@laxodds.com
ADMIN_PASSWORD=changeme123

# Optional: Session secret for additional security
SESSION_SECRET=another-secret-key-for-sessions
