# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (PostgreSQL)
# For local development:
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/laxodds

# For production (e.g., Railway, Render, Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# SSL for PostgreSQL connections
# Set to false for local Docker/Homebrew Postgres, true for managed providers that require SSL
DB_SSL=false

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration
JWT_EXPIRES_IN=7d

# Scraping Schedule (cron format: minute hour day month weekday)
# Default: Every 6 hours
SCRAPE_CRON=0 */6 * * *
POSTGAME_SCRAPE_DELAY_HOURS=3
POSTGAME_SCRAPE_POLL_CRON=*/15 * * * *
POSTGAME_LOOKBACK_DAYS=2
GAME_TIMEZONE=America/Chicago

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@laxodds.com
ADMIN_PASSWORD=changeme123

# Optional: Session secret for additional security
SESSION_SECRET=another-secret-key-for-sessions
